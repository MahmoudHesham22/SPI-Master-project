
package main_seq_start;
import uvm_pkg::*;
`include "uvm_macros.svh"
import SPI_seq_item ::*;




class main_seq extends uvm_sequence;
    `uvm_object_utils(main_seq )
    SPI_seq_item seq_item;

    function new(string name="main_seq ") ;
        super.new(name);
    endfunction

    task body;
    seq_item = SPI_seq_item::type_id::create("seq_item");
    start_item(seq_item);
    seq_item.SS_n = 0;
    seq_item.rst_n = 1; 
    seq_item.MOSI = 0;
    seq_item.tx_valid = 0;
    seq_item.tx_data = 8'h00;
    seq_item.MOSI_data = 11'b00000000000;
        
    finish_item(seq_item);
    start_item(seq_item);
    seq_item.MOSI = 0;      
    finish_item(seq_item);

    

    endtask


endclass

endpackage




